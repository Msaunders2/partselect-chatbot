{
  "name": "chrome-side-panel",
  "version": "0.1.0",
  "private": true,
  "homepage": ".",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.6.2",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "antd": "^5.12.1",
    "axios": "^1.13.5",
    "cheerio": "^1.2.0",
    "chromadb": "^1.10.5",
    "chrome": "^0.1.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "framer-motion": "^10.16.4",
    "fs": "^0.0.1-security",
    "langchain": "^0.0.143",
    "marked": "^9.1.2",
    "mui": "^0.0.1",
    "openai": "^4.20.1",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^19.11.1",
    "react": "^18.2.0",
    "react-chat-elements": "^12.0.10",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.15.0",
    "react-scripts": "5.0.1",
    "rsuite": "^5.41.0",
    "rxjs": "^7.8.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "server": "node server/services/server.js",
    "kill": "bash scripts/kill-servers.sh",
    "dev": "npm run kill && concurrently \"npm run start\" \"npm run server\"",
    "scrape:bs4": ".venv/bin/python scripts/scrape_partselect_bs4.py",
    "scrape:bs4:blog": ".venv/bin/python scripts/scrape_partselect_bs4.py --blog",
    "scrape:bs4:brands-products": ".venv/bin/python scripts/scrape_partselect_bs4.py --brands-products",
    "scrape:bs4:brands-products:fresh": ".venv/bin/python scripts/scrape_partselect_bs4.py --brands-products --fresh-browser",
    "scrape:bs4:brands-products:vector-db": ".venv/bin/python scripts/scrape_partselect_bs4.py --brands-products --fresh-browser --vector-db",
    "chroma:server": ".venv/bin/chroma run --path server/data/chroma",
    "chroma:server:docker": "docker run --rm -p 8000:8000 -v \"$(pwd)/server/data/chroma:/chroma/chroma\" -e IS_PERSISTENT=TRUE chromadb/chroma:latest",
    "scrape:bs4:brands:fresh": ".venv/bin/python scripts/scrape_partselect_bs4.py --brands-only --fresh-browser",
    "scrape:bs4:products:fresh": ".venv/bin/python scripts/scrape_partselect_bs4.py --products-only --fresh-browser",
    "scrape:bs4:setup": "python3 -m venv .venv && .venv/bin/pip install -r scripts/requirements-scraper.txt && .venv/bin/playwright install chromium",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:server": "node --test server/services/transactionService.test.js",
    "test:transaction-api": "node scripts/test-transaction-api.js",
    "test:product-chat": "node scripts/test-product-chat.js",
    "check": "node scripts/check-setup.js",
    "check:api": "node scripts/check-setup.js --api",
    "check:scraper": ".venv/bin/python scripts/scrape_partselect_bs4.py --check",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
